---
import FeedItem from "../../../components/FeedItem.astro";
import PatternLayout from "../../../layouts/PatternLayout.astro";
import { feedPage, TOTAL_PAGES } from "../../../data/feed";

export function getStaticPaths() {
  return Array.from({ length: TOTAL_PAGES }, (_, i) => ({
    params: { page: String(i + 1) },
  }));
}

const page = Number(Astro.params.page);
const items = feedPage(page);
const base = import.meta.env.BASE_URL;
const nextHref =
  page < TOTAL_PAGES ? `${base}extra/seamless-paging/${page + 1}` : null;
---

<PatternLayout
  title="Seamless Pagination"
  assumption="SPA router + client-side query cache"
  technique="Static pages + IntersectionObserver + DOMParser + replaceState"
  layer="1-3"
  jsShipped="inline <script> only"
>
  <p class="text-sm text-muted mb-2">
    Page <span id="page-indicator">{page}</span> of {TOTAL_PAGES} — watch the
    URL advance as you scroll.
  </p>
  <ul id="list" class="border border-border rounded-md bg-surface">
    {items.map((item) => <FeedItem item={item} />)}
  </ul>
  {
    nextHref ? (
      <a
        id="load-more"
        href={nextHref}
        class="block py-4 text-center text-primary"
      >
        Load more
      </a>
    ) : (
      <p id="list-end" class="py-4 text-center text-sm text-muted">
        — End of list —
      </p>
    )
  }
  <p class="text-muted text-sm mt-2">
    Scroll to the bottom. The next statically generated page is fetched and its
    list items are spliced in, while <code>replaceState</code> advances the
    URL — reload or share and you land on a real page. Without JavaScript,
    "Load more" is a plain link and the demo degrades to ordinary pagination:
    the full crumple zone.
  </p>
  <p class="mt-4">
    <a href={`${base}extra/infinite-scroll`}
      >Compare: Infinite Scroll (Feed) →</a
    >
  </p>
</PatternLayout>

<script>
  let observer: IntersectionObserver | null = null;

  document.addEventListener("astro:page-load", () => {
    observer?.disconnect();
    const list = document.getElementById("list");
    const link = document.getElementById(
      "load-more",
    ) as HTMLAnchorElement | null;
    const indicator = document.getElementById("page-indicator");
    if (!list || !link) return;

    let loading = false;

    async function loadNext() {
      if (loading || !list || !link) return;
      loading = true;
      const pageHref = link.href;
      try {
        const res = await fetch(pageHref);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const doc = new DOMParser().parseFromString(
          await res.text(),
          "text/html",
        );
        const items = doc.querySelectorAll("#list > li");
        if (items.length === 0) throw new Error("unexpected response");
        for (const li of items) list.appendChild(li);
        history.replaceState(null, "", pageHref);
        if (indicator) {
          const page = new URL(pageHref).pathname.split("/").filter(Boolean).pop();
          if (page) indicator.textContent = page;
        }
        const nextLink = doc.getElementById("load-more");
        const nextHref = nextLink?.getAttribute("href");
        if (nextHref) {
          link.href = new URL(nextHref, pageHref).href;
          // Re-observe so the callback fires again if the link is still in view
          observer?.unobserve(link);
          observer?.observe(link);
        } else {
          observer?.disconnect();
          const end = doc.getElementById("list-end");
          if (end) link.replaceWith(end);
          else link.remove();
        }
      } catch {
        // Crumple zone: stop auto-loading; the link keeps working as plain navigation
        observer?.disconnect();
        link.textContent = "Load more (auto-load unavailable)";
      } finally {
        loading = false;
      }
    }

    observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) loadNext();
      },
      { rootMargin: "200px" },
    );
    observer.observe(link);
  });
</script>
