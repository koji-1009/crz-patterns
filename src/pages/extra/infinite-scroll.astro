---
import FeedItem from "../../components/FeedItem.astro";
import PatternLayout from "../../layouts/PatternLayout.astro";
import { feedPage, PAGE_SIZE, TOTAL_PAGES } from "../../data/feed";

const firstChunk = feedPage(1);
const base = import.meta.env.BASE_URL;
---

<PatternLayout
  title="Infinite Scroll (Feed)"
  assumption="useInfiniteQuery + react-infinite-scroll-component"
  technique="IntersectionObserver + fetch + <template> + content-visibility"
  layer="1-3"
  jsShipped="inline <script> only"
>
  <div
    id="feed-box"
    class="h-[28rem] overflow-y-auto border border-border rounded-md bg-surface"
  >
    <ul id="feed">
      {firstChunk.map((item) => <FeedItem item={item} />)}
    </ul>
    <div
      id="sentinel"
      class="h-14 flex items-center justify-center text-sm text-muted"
      data-endpoint={`${base}extra/infinite-scroll/feed/`}
      data-next-page="2"
      data-total-pages={TOTAL_PAGES}
      data-page-size={PAGE_SIZE}
    >
    </div>
  </div>
  <template id="item-template">
    <FeedItem />
  </template>
  <noscript>
    <p class="py-4 text-center text-sm text-muted">
      JavaScript is disabled — only the first {PAGE_SIZE} items are available.
    </p>
  </noscript>
  <p class="text-muted text-sm mt-2">
    Scroll the list. Upcoming rows are reserved as placeholder skeletons (cf.
    Android Paging's <code>enablePlaceholders</code>), so chunks fetched as
    build-time JSON fade into already-reserved space instead of shifting
    layout. The URL never changes: reload starts over, and without JavaScript
    nothing past the first chunk is reachable. That is the feed pattern's
    inherent trade-off, not an implementation shortcut. Each row uses
    <code>content-visibility: auto</code>, so off-screen rows skip layout and
    paint.
  </p>
  <p class="mt-4">
    <a href={`${base}extra/seamless-paging/1`}
      >Compare: Seamless Pagination →</a
    >
  </p>
</PatternLayout>

<script>
  let observer: IntersectionObserver | null = null;

  document.addEventListener("astro:page-load", () => {
    observer?.disconnect();
    const boxEl = document.getElementById("feed-box");
    const feedEl = document.getElementById("feed");
    const sentinelEl = document.getElementById("sentinel");
    const templateEl = document.getElementById(
      "item-template",
    ) as HTMLTemplateElement | null;
    if (!boxEl || !feedEl || !sentinelEl || !templateEl) return;
    // Narrowed bindings: hoisted inner functions don't inherit the guard above
    const box = boxEl;
    const feed = feedEl;
    const sentinel = sentinelEl;
    const template = templateEl;

    let nextPage = Number(sentinel.dataset.nextPage);
    const totalPages = Number(sentinel.dataset.totalPages);
    const pageSize = Number(sentinel.dataset.pageSize);
    const endpoint = sentinel.dataset.endpoint ?? "";
    let skeletons: HTMLLIElement[] = [];
    let loading = false;

    function makeSkeleton(): HTMLLIElement | null {
      const node = template.content.cloneNode(true) as DocumentFragment;
      return node.querySelector("li");
    }

    // Placeholder rows are a Layer 3 affordance, so they are inserted here
    // rather than in the build-time HTML — the no-JS page stays clean.
    function appendSkeletons() {
      skeletons = [];
      for (let i = 0; i < pageSize; i++) {
        const li = makeSkeleton();
        if (!li) continue;
        feed.appendChild(li);
        skeletons.push(li);
      }
      // Observing the first placeholder starts the fetch just as the
      // reserved space approaches, so skeletons are visible only briefly
      const first = skeletons[0];
      if (first) observer?.observe(first);
    }

    function fill(
      li: HTMLLIElement,
      item: { title: string; body: string; seed: string },
    ) {
      const img = li.querySelector("img");
      if (img) {
        img.src = `https://picsum.photos/seed/${item.seed}/128/128`;
        img.alt = item.title;
      }
      const text = li.querySelector("div");
      if (text) {
        // Snap to transparent without transitioning, then fade the content in
        text.style.transition = "none";
        text.style.opacity = "0";
      }
      const title = li.querySelector("[data-title]");
      if (title) title.textContent = item.title;
      const body = li.querySelector("[data-body]");
      if (body) body.textContent = item.body;
      li.dataset.state = "filled";
      if (text) {
        void text.offsetWidth;
        text.style.transition = "";
        text.style.opacity = "";
      }
    }

    async function loadNext() {
      if (loading) return;
      loading = true;
      try {
        const res = await fetch(`${endpoint}${nextPage}.json`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const items: { title: string; body: string; seed: string }[] =
          await res.json();
        observer?.disconnect();
        items.forEach((item, i) => {
          let li = skeletons[i];
          if (!li) {
            const extra = makeSkeleton();
            if (!extra) return;
            feed.appendChild(extra);
            li = extra;
          }
          fill(li, item);
        });
        for (const leftover of skeletons.slice(items.length)) leftover.remove();
        nextPage++;
        if (nextPage > totalPages) {
          skeletons = [];
          sentinel.textContent = "— End of feed —";
        } else {
          appendSkeletons();
        }
      } catch {
        observer?.disconnect();
        const btn = document.createElement("button");
        btn.textContent = "Load failed — Retry";
        btn.className =
          "bg-primary text-white border border-primary rounded-sm px-4 py-2 cursor-pointer hover:bg-primary-hover";
        btn.onclick = () => {
          sentinel.replaceChildren();
          loadNext();
        };
        sentinel.replaceChildren(btn);
      } finally {
        loading = false;
      }
    }

    observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) loadNext();
      },
      { root: box, rootMargin: "200px" },
    );

    if (nextPage <= totalPages) appendSkeletons();
    else sentinel.textContent = "— End of feed —";
  });
</script>
