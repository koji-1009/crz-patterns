---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="404 — CRZ Patterns">
  <main class="flex flex-col items-center justify-center min-h-[50vh] text-center">
    <h1 class="text-6xl font-bold text-muted mb-4">404</h1>
    <p class="text-lg text-muted mb-6">Page not found.</p>
    <a
      href={base}
      class="bg-primary text-white border border-primary rounded-sm px-4 py-2 no-underline hover:bg-primary-hover"
    >Back to catalog</a>
  </main>
</Layout>
