---
import PatternLayout from "../../../layouts/PatternLayout.astro";
const base = import.meta.env.BASE_URL;
---

<PatternLayout
  title="Multi-step Form — Step 3 of 3"
  assumption="useState + Router for step management"
  technique="sessionStorage for inter-step data + URL for current step"
  layer="1"
  jsShipped="inline <script> only"
>
  <p class="text-muted mb-4">Step 3: Confirmation</p>
  <div
    id="confirm"
    class="grid gap-2 p-4 bg-surface-alt rounded-sm max-w-[400px] mb-4"
  >
  </div>
  <div class="flex gap-4">
    <a
      href={`${base}forms/multi-step/step2`}
      class="px-4 py-2 border border-border rounded-sm">&larr; Back</a
    >
    <button
      type="button"
      id="submit-btn"
      class="bg-primary text-white border border-primary rounded-sm px-4 py-2 cursor-pointer hover:bg-primary-hover"
      >Confirm & Submit</button
    >
  </div>
  <script>
    import { navigate } from "astro:transitions/client";
    const KEY = "multi-step";

    function escapeHtml(s: string): string {
      const div = document.createElement("div");
      div.textContent = s;
      return div.innerHTML;
    }

    document.addEventListener("astro:page-load", () => {
      const container = document.getElementById(
        "confirm",
      ) as HTMLElement | null;
      const btn = document.getElementById(
        "submit-btn",
      ) as HTMLButtonElement | null;
      if (!container || !btn) return;

      const saved = sessionStorage.getItem(KEY);
      if (!saved) {
        navigate(`${import.meta.env.BASE_URL}forms/multi-step/step1`);
        return;
      }
      const d = JSON.parse(saved);

      container.innerHTML = "";
      const fields = [
        ["Name", d.name],
        ["Email", d.email],
        ["Address", d.address],
        ["Phone", d.phone],
      ] as const;
      for (const [label, value] of fields) {
        const row = document.createElement("div");
        const strong = document.createElement("strong");
        strong.textContent = `${label}: `;
        row.appendChild(strong);
        row.appendChild(document.createTextNode(escapeHtml(value ?? "")));
        container.appendChild(row);
      }

      btn.addEventListener("click", () => {
        sessionStorage.removeItem(KEY);
        container.textContent = "";
        const p = document.createElement("p");
        p.textContent = "Submitted! All data cleared from sessionStorage.";
        container.appendChild(p);
        btn.remove();
      });
    });
  </script>
</PatternLayout>
